rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserSpace(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if ownsUserSpace(uid);

      match /tasks/{taskId} {
        allow read, delete: if ownsUserSpace(uid);
        allow create: if ownsUserSpace(uid) && request.resource.data.userId == uid;
        allow update: if ownsUserSpace(uid)
          && resource.data.userId == uid
          && request.resource.data.userId == uid;
      }

      match /projects/{projectId} {
        allow read, delete: if ownsUserSpace(uid);
        allow create: if ownsUserSpace(uid)
          && request.resource.data.userId == uid
          && request.resource.data.id == projectId;
        allow update: if ownsUserSpace(uid)
          && resource.data.userId == uid
          && request.resource.data.userId == uid
          && request.resource.data.id == projectId;
      }

      match /filters/{filterId} {
        allow read, delete: if ownsUserSpace(uid);
        allow create: if ownsUserSpace(uid)
          && request.resource.data.userId == uid
          && request.resource.data.id == filterId;
        allow update: if ownsUserSpace(uid)
          && resource.data.userId == uid
          && request.resource.data.userId == uid
          && request.resource.data.id == filterId;
      }

      match /dailyPlans/{dateId} {
        allow read, delete: if ownsUserSpace(uid);
        allow create: if ownsUserSpace(uid)
          && request.resource.data.userId == uid
          && request.resource.data.id == dateId
          && request.resource.data.date == dateId;
        allow update: if ownsUserSpace(uid)
          && resource.data.userId == uid
          && request.resource.data.userId == uid
          && request.resource.data.id == dateId
          && request.resource.data.date == dateId;
      }

      match /focusSessions/{sessionId} {
        allow read, delete: if ownsUserSpace(uid);
        allow create: if ownsUserSpace(uid)
          && request.resource.data.userId == uid
          && request.resource.data.id == sessionId;
        allow update: if ownsUserSpace(uid)
          && resource.data.userId == uid
          && request.resource.data.userId == uid
          && request.resource.data.id == sessionId;
      }

      match /settings/{settingId} {
        allow read, create, update, delete: if ownsUserSpace(uid) && settingId == "main";
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
